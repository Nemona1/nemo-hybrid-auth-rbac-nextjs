{
  "name": "nemo-auth-nextjs",
  "version": "1.0.3",
  "description": "Complete authentication system for Next.js - Copy everything you need for enterprise-grade auth",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "scripts": {
    "build": "rollup -c",
    "prepare": "npm run build",
    "postinstall": "node scripts/copy-all.js"
  },
